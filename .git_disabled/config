[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "FadeTima"]
	url = https://github.com/Lamech001/UnifyApp
	fetch = +refs/heads/*:refs/remotes/FadeTima/*
[branch "master"]
	remote = FadeTima
	merge = refs/heads/master
[branch "main"]
	vscode-merge-base = FadeTima/master
	remote = origin
	merge = refs/heads/main
[remote "origin"]
	url = https://github.com/Lamech001/UnifyApp.git
	fetch = +refs/heads/*:refs/remotes/origin/*
